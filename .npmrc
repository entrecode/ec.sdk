# Newer npm (>= the runner's npm@latest) blocks non-registry dependency fetches
# by default (EALLOWGIT / EALLOWREMOTE). ec.sdk pulls the entrecode `tv4` fork
# (a github tarball, see the `overrides` in package.json) transitively via
# json-schema-remote, so re-enable git and remote/tarball fetching explicitly.
allow-git=all
allow-remote=all
